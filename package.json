{
  "name": "blind-turn",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.17 <23",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "concurrently -k -n WEB,SERVER -c cyan,green \"pnpm --filter @blind-turn/web dev\" \"pnpm --filter @blind-turn/server dev\"",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @blind-turn/web build",
    "start:web": "pnpm --filter @blind-turn/web start",
    "build:server": "pnpm --filter @blind-turn/server build",
    "start:server": "pnpm --filter @blind-turn/server start",
    "test": "pnpm -r --if-present test",
    "lint": "eslint apps packages --max-warnings=0",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
